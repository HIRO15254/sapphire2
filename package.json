{
  "name": "sapphire2",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.1",
      "zod": "^4.3.6",
      "typescript": "^6.0.2",
      "@types/bun": "^1.3.11",
      "hono": "^4.12.12",
      "@trpc/server": "^11.16.0",
      "better-auth": "^1.6.0",
      "@trpc/client": "^11.16.0",
      "drizzle-orm": "^0.45.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "check-types:root": "tsc --noEmit",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "db:studio": "bun run --filter @sapphire2/db db:studio",
    "db:generate": "bun run --filter @sapphire2/db db:generate",
    "db:migrate:local": "wrangler d1 migrations apply sapphire2-db --local -c apps/server/wrangler.toml",
    "db:migrate:remote": "wrangler d1 migrations apply sapphire2-db --remote -c apps/server/wrangler.toml",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "release:validate": "bun run ./scripts/releases/validate.ts",
    "release:validate-local": "bun run ./scripts/releases/validate-local.ts",
    "release:prepare-main-pr": "bun run ./scripts/releases/prepare-main-pr.ts",
    "release:publish": "bun run ./scripts/releases/publish.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@sapphire2/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@sapphire2/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "catalog:",
    "ultracite": "7.4.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.10"
}
