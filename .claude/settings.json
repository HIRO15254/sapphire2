{
  "permissions": {
    "allow": [
      "Bash(gh release create*)",
      "Bash(gh release view*)",
      "Bash(gh pr comment*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun x ultracite fix && bun x vitest run --changed HEAD && bun x ultracite check"
          }
        ]
      }
    ]
  }
}
