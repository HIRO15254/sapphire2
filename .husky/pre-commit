#!/usr/bin/env sh
# Auto-stage routeTree.gen.ts if it has unstaged changes
# (prevents lint-staged stash conflicts with this auto-generated file)
if git diff --name-only | grep -q 'routeTree.gen.ts'; then
  git add apps/web/src/routeTree.gen.ts
fi

bun x lint-staged

# Run only the tests related to staged files (not the full suite).
# Full suite is enforced by the Claude Code Stop hook instead.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx')
if [ -n "$STAGED" ]; then
  bun x vitest related --run $STAGED
fi
